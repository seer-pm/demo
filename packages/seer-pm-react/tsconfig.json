{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@seer-pm/sdk": ["../seer-pm-sdk/src", "../seer-pm-sdk/dist"],
      "@seer-pm/sdk/*": ["../seer-pm-sdk/src/*", "../seer-pm-sdk/dist/*"]
    },
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist"
  },
  "include": ["src"]
}

