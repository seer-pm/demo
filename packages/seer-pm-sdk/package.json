{
  "name": "@seer-pm/sdk",
  "version": "0.0.1",
  "description": "SDK for the Seer prediction market protocol: create markets, resolve, split/merge/redeem, and trade",
  "license": "MIT",
  "author": "Seer",
  "repository": {
    "type": "git",
    "url": "https://github.com/seer-pm/seer-pm.git",
    "directory": "packages/seer-sdk"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./contracts/curate": "./generated/contracts/curate.ts",
    "./contracts/reality": "./generated/contracts/reality.ts",
    "./contracts/arbitrators": "./generated/contracts/arbitrators.ts",
    "./contracts/market-factory": "./generated/contracts/market-factory.ts",
    "./contracts/market-view": "./generated/contracts/market-view.ts",
    "./contracts/router": "./generated/contracts/router.ts",
    "./contracts/multi-drop": "./generated/contracts/multi-drop.ts",
    "./contracts/trading-credits": "./generated/contracts/trading-credits.ts",
    "./subgraph/seer": "./generated/subgraph/seer.ts",
    "./subgraph/tokens": "./generated/subgraph/tokens.ts",
    "./subgraph/curate": "./generated/subgraph/curate.ts",
    "./subgraph/swapr": "./generated/subgraph/swapr.ts",
    "./subgraph/uniswap": "./generated/subgraph/uniswap.ts",
    "./subgraph/reality": "./generated/subgraph/reality.ts",
    "./abis/eternal-farming": "./abis/EternalFarmingAbi.ts"
  },
  "files": ["dist", "generated/contracts", "generated/subgraph", "abis", "queries", "README.md"],
  "scripts": {
  "build": "yarn generate && tsup src/index.ts --format cjs,esm --dts --clean --external wagmi,@wagmi/core,react,react-dom,viem,@tanstack/react-query",
  "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external wagmi,@wagmi/core,react,react-dom,viem,@tanstack/react-query",
  "generate": "wagmi generate",
  "generate:gql": "graphql-codegen",
  "prepublishOnly": "yarn generate"
  },
  "peerDependencies": {
    "@wagmi/core": ">=2.0.0",
    "graphql-request": ">=5.0.0",
    "graphql-tag": ">=2.0.0",
    "viem": ">=2.0.0",
    "wagmi": "^2.0.0 || ^3.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript": "^4.0.0",
    "@graphql-codegen/typescript-graphql-request": "6.2.0",
    "@graphql-codegen/typescript-operations": "^4.2.0",
    "@wagmi/cli": "^2.1.22",
    "tsup": "^8.0.2",
    "typescript": "^5.2.2",
    "viem": "^2.38.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@uniswap/v3-sdk": "^3.19.0",
    "@cowprotocol/cow-sdk": "^5.3.2",
    "@swapr/sdk": "https://github.com/seer-pm/swapr-sdk#4fc1e9ce71f76612aa6f468b5b381083d4c52b86",
    "ethers": "^5.7.2"
  }
}
